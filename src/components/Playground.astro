<section class="section">
    <div class="section-label">// playground</div>
    <div class="section-title">Run code in the browser</div>
    <p class="section-desc">
        Pick a language, edit the snippet, and hit Run. Executes on the
        <a
            href="https://github.com/engineer-man/piston"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-link">Piston</a
        > sandbox — nothing runs on my machine.
    </p>

    <div class="pg-shell" id="playground">
        <!-- Tab bar -->
        <div class="pg-tabs" id="pgTabs">
            <button class="pg-tab active" data-lang="go" data-ext="go"
                >Go</button
            >
            <button class="pg-tab" data-lang="rust" data-ext="rs">Rust</button>
            <button class="pg-tab" data-lang="python" data-ext="py"
                >Python</button
            >
            <button class="pg-tab" data-lang="cpp" data-ext="cpp">C++</button>
            <button class="pg-tab" data-lang="typescript" data-ext="ts"
                >TypeScript</button
            >
        </div>

        <!-- Editor -->
        <div class="pg-editor-wrap">
            <div class="pg-line-nums" id="lineNums" aria-hidden="true"></div>
            <textarea
                id="pgEditor"
                class="pg-editor"
                spellcheck="false"
                autocorrect="off"
                autocapitalize="off"
                aria-label="Code editor"></textarea>
        </div>

        <!-- Toolbar -->
        <div class="pg-toolbar">
            <span class="pg-lang-label" id="langLabel">main.go</span>
            <div class="pg-toolbar-right">
                <button
                    class="pg-btn-reset"
                    id="btnReset"
                    title="Reset to default snippet"
                >
                    <i class="ti ti-refresh" aria-hidden="true"></i> Reset
                </button>
                <button class="pg-btn-run" id="btnRun">
                    <i class="ti ti-player-play" aria-hidden="true"></i>
                    <span id="runLabel">Run</span>
                </button>
            </div>
        </div>

        <!-- Output -->
        <div class="pg-output-wrap">
            <div class="pg-output-header">
                <span class="pg-output-label">
                    <i class="ti ti-terminal-2" aria-hidden="true"></i> stdout
                </span>
                <span class="pg-status" id="pgStatus"></span>
            </div>
            <pre
                class="pg-output"
                id="pgOutput"><span class="pg-output-placeholder">// output appears here after you run the code</span></pre>
        </div>
    </div>
</section>

<style>
    .section {
        padding: 40px 28px;
        border-bottom: 1px solid #21262d;
    }
    .section-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: #7ee787;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 6px;
    }
    .section-title {
        font-size: 22px;
        font-weight: 500;
        margin-bottom: 8px;
        color: #f0f6fc;
    }
    .section-desc {
        font-size: 13px;
        color: #8b949e;
        margin-bottom: 24px;
        line-height: 1.6;
    }
    .inline-link {
        color: #58a6ff;
        text-decoration: none;
    }
    .inline-link:hover {
        text-decoration: underline;
    }

    /* Shell wrapper */
    .pg-shell {
        border: 1px solid #30363d;
        border-radius: 8px;
        overflow: hidden;
        background: #0d1117;
    }

    /* Tabs */
    .pg-tabs {
        display: flex;
        gap: 0;
        background: #161b22;
        border-bottom: 1px solid #21262d;
        overflow-x: auto;
        scrollbar-width: none;
    }
    .pg-tabs::-webkit-scrollbar {
        display: none;
    }
    .pg-tab {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        padding: 9px 16px;
        background: transparent;
        color: #8b949e;
        border: none;
        border-right: 1px solid #21262d;
        cursor: pointer;
        white-space: nowrap;
        transition:
            color 0.15s,
            background 0.15s;
    }
    .pg-tab:hover {
        color: #f0f6fc;
        background: #1c2128;
    }
    .pg-tab.active {
        color: #f0f6fc;
        background: #0d1117;
        border-bottom: 2px solid #7ee787;
        margin-bottom: -1px;
    }

    /* Editor area */
    .pg-editor-wrap {
        display: flex;
        position: relative;
        background: #0d1117;
    }
    .pg-line-nums {
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        color: #484f58;
        text-align: right;
        padding: 16px 10px 16px 16px;
        user-select: none;
        min-width: 44px;
        background: #0d1117;
        border-right: 1px solid #21262d;
    }
    .pg-editor {
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        color: #e6edf3;
        background: transparent;
        border: none;
        outline: none;
        resize: none;
        width: 100%;
        padding: 16px;
        tab-size: 4;
        -moz-tab-size: 4;
        min-height: 220px;
        caret-color: #7ee787;
    }
    .pg-editor::selection {
        background: #388bfd33;
    }

    /* Toolbar */
    .pg-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 14px;
        background: #161b22;
        border-top: 1px solid #21262d;
    }
    .pg-lang-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: #484f58;
    }
    .pg-toolbar-right {
        display: flex;
        gap: 8px;
        align-items: center;
    }
    .pg-btn-reset {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        padding: 5px 10px;
        background: transparent;
        color: #8b949e;
        border: 1px solid #30363d;
        border-radius: 5px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 4px;
        transition:
            color 0.15s,
            border-color 0.15s;
    }
    .pg-btn-reset:hover {
        color: #f0f6fc;
        border-color: #8b949e;
    }
    .pg-btn-run {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        font-weight: 700;
        padding: 6px 16px;
        background: #238636;
        color: #f0f6fc;
        border: 1px solid #2ea043;
        border-radius: 6px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background 0.15s;
    }
    .pg-btn-run:hover {
        background: #2ea043;
    }
    .pg-btn-run:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* Output */
    .pg-output-wrap {
        border-top: 1px solid #21262d;
    }
    .pg-output-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 7px 14px;
        background: #161b22;
        border-bottom: 1px solid #21262d;
    }
    .pg-output-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 11px;
        color: #484f58;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .pg-status {
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        padding: 2px 7px;
        border-radius: 3px;
    }
    .pg-status.ok {
        background: #23863633;
        color: #7ee787;
        border: 1px solid #23863660;
    }
    .pg-status.err {
        background: #da363333;
        color: #ff7b72;
        border: 1px solid #da363360;
    }
    .pg-status.run {
        background: #3776ab33;
        color: #7ec8e3;
        border: 1px solid #3776ab60;
    }
    .pg-output {
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        color: #e6edf3;
        background: #010409;
        padding: 16px;
        margin: 0;
        min-height: 80px;
        max-height: 260px;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .pg-output-placeholder {
        color: #484f58;
    }
    .pg-output.has-error {
        color: #ff7b72;
    }
</style>

<script>
    // ── Snippets ──────────────────────────────────────────────────────────────
    const GO_IMPORT = String.fromCharCode(105, 109, 112, 111, 114, 116) + ' "fmt"';
    const SNIPPETS = {
        go: `package main

${GO_IMPORT}

func main() {
    fmt.Println("Hello, World!")
}`,
        rust: `fn main() {
    println!("Hello, World!");
}`,
        python: `print("Hello, World!")`,
        cpp: `#include <iostream>

int main() {
    std::cout << "Hello, World!" << std::endl;
    return 0;
}`,
        typescript: `console.log("Hello, World!");`,
    };

    // Piston language identifiers
    const LANG_ID = {
        go: "go",
        rust: "rust",
        python: "python",
        cpp: "c++",
        typescript: "typescript",
    };

    const FILE_EXT = {
        go: "main.go",
        rust: "main.rs",
        python: "main.py",
        cpp: "main.cpp",
        typescript: "main.ts",
    };

    // ── State ─────────────────────────────────────────────────────────────────
    let currentLang = "go";

    // ── DOM refs ──────────────────────────────────────────────────────────────
    const editor = document.getElementById("pgEditor");
    const output = document.getElementById("pgOutput");
    const lineNums = document.getElementById("lineNums");
    const btnRun = document.getElementById("btnRun");
    const btnReset = document.getElementById("btnReset");
    const runLabel = document.getElementById("runLabel");
    const pgStatus = document.getElementById("pgStatus");
    const langLabel = document.getElementById("langLabel");
    const tabs = document.querySelectorAll(".pg-tab");

    // ── Helpers ───────────────────────────────────────────────────────────────
    function updateLineNums() {
        const lines = editor.value.split("\n").length;
        lineNums.textContent = Array.from(
            { length: lines },
            (_, i) => i + 1,
        ).join("\n");
    }

    function setStatus(text, cls) {
        pgStatus.textContent = text;
        pgStatus.className = "pg-status " + cls;
    }

    function loadSnippet(lang) {
        currentLang = lang;
        editor.value = SNIPPETS[lang];
        langLabel.textContent = FILE_EXT[lang];
        updateLineNums();
        output.innerHTML =
            '<span class="pg-output-placeholder">// output appears here after you run the code</span>';
        output.classList.remove("has-error");
        pgStatus.textContent = "";
        pgStatus.className = "pg-status";
    }

    // Sync textarea scroll with line numbers
    editor.addEventListener("scroll", () => {
        lineNums.scrollTop = editor.scrollTop;
    });

    editor.addEventListener("input", updateLineNums);

    // Tab key inserts spaces instead of moving focus
    editor.addEventListener("keydown", (e) => {
        if (e.key === "Tab") {
            e.preventDefault();
            const start = editor.selectionStart;
            const end = editor.selectionEnd;
            editor.value =
                editor.value.slice(0, start) + "    " + editor.value.slice(end);
            editor.selectionStart = editor.selectionEnd = start + 4;
            updateLineNums();
        }
    });

    // ── Tab switching ─────────────────────────────────────────────────────────
    tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
            tabs.forEach((t) => t.classList.remove("active"));
            tab.classList.add("active");
            loadSnippet(tab.dataset.lang);
        });
    });

    btnReset.addEventListener("click", () => loadSnippet(currentLang));

    // ── Run code via Piston API ───────────────────────────────────────────────
    btnRun.addEventListener("click", async () => {
        btnRun.disabled = true;
        runLabel.textContent = "Running…";
        setStatus("running", "run");
        output.classList.remove("has-error");
        output.textContent = "";

        try {
            // Fetch available runtimes to get the latest version for the language
            const rtRes = await fetch(
                "https://emkc.org/api/v2/piston/runtimes",
            );
            const runtimes = await rtRes.json();
            const langId = LANG_ID[currentLang];
            const rt = runtimes
                .filter((r) => r.language === langId)
                .sort((a, b) =>
                    b.version.localeCompare(a.version, undefined, {
                        numeric: true,
                    }),
                )[0];

            if (!rt) throw new Error(`Runtime not found for ${langId}`);

            const res = await fetch("https://emkc.org/api/v2/piston/execute", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    language: rt.language,
                    version: rt.version,
                    files: [
                        { name: FILE_EXT[currentLang], content: editor.value },
                    ],
                    stdin: "",
                    args: [],
                    compile_timeout: 10000,
                    run_timeout: 5000,
                }),
            });

            const data = await res.json();
            const run = data.run || {};
            const stdout = run.stdout || run.output || "";
            const stderr = run.stderr || "";
            const compileErr = data.compile?.stderr || "";
            const exitCode = run.code ?? 0;

            console.log('[playground] response:', data);

            const combined = [compileErr, stderr, stdout]
                .filter(Boolean)
                .join("\n")
                .trim();

            if (combined) {
                output.textContent = combined;
            } else {
                output.textContent = "(no output)";
                console.warn('[playground] empty output for:', data);
            }

            if (exitCode === 0 && !compileErr && !stderr) {
                setStatus(`✓ exit 0`, "ok");
            } else {
                setStatus(`exit ${exitCode}`, "err");
                output.classList.add("has-error");
            }
        } catch (err) {
            output.textContent = `Error: ${err.message}\n\nThe Piston sandbox may be temporarily unavailable.`;
            output.classList.add("has-error");
            setStatus("error", "err");
        } finally {
            btnRun.disabled = false;
            runLabel.textContent = "Run";
        }
    });

    // ── Init ──────────────────────────────────────────────────────────────────
    loadSnippet("go");
</script>
